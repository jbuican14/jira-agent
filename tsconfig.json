{
     "compilerOptions": {
       "target": "ES2022",
       "lib": ["ES2022", "DOM", "DOM.Iterable"],
       "module": "ESNext",
       "moduleResolution": "Bundler",
       "jsx": "react-jsx",
       "allowJs": true,
       "esModuleInterop": true,
       "skipLibCheck": true,
       "strict": false,
       "noEmit": true,
       "isolatedModules": true,
       "resolveJsonModule": true
     },
     "include": ["src"]
}